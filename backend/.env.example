# =============================================================
# LLM Trading Analyzer - Backend Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# -------- Database --------
# Local development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./data/trader.db
# Production (PostgreSQL) — use this when deploying with docker-compose:
# DATABASE_URL=postgresql+asyncpg://trader:changeme@postgres:5432/trader

# -------- Security --------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Admin token for /api/admin/* endpoints
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
ADMIN_TOKEN=change-this-admin-token

# -------- JWT --------
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -------- LLM Configuration --------
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.7

# -------- CORS --------
# Comma-separated list of allowed origins. Use * for local dev only.
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=*

# -------- 爱发电 Webhook --------
# Found in 爱发电 Dashboard > 开发者设置 > Webhook token
AFDIAN_WEBHOOK_TOKEN=
# 爱发电 plan IDs (from plan URL)
AFDIAN_BASIC_PLAN_ID=
AFDIAN_PREMIUM_PLAN_ID=
# 爱发电 subscription page links
AFDIAN_BASIC_LINK=https://afdian.com/order/create?plan_id=xxx
AFDIAN_PREMIUM_LINK=https://afdian.com/order/create?plan_id=xxx

# -------- 爱发电 Open API (主动查询模式，不需要 Webhook 域名) --------
# 在 afdian.net/dashboard/dev 获取
AFDIAN_USER_ID=
AFDIAN_API_TOKEN=

# -------- Server --------
HOST=0.0.0.0
PORT=8000

# -------- Email / Resend (https://resend.com) --------
# 注册 Resend 免费账号，获取 API Key，每月免费 3000 封
# 留空则验证链接将打印到后端日志（适合本地开发）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=财财技术洞见 <noreply@yourdomain.com>

# Base URL of the frontend (used to build verification links)
APP_BASE_URL=https://yourdomain.com
