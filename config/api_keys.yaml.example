# API密钥配置模板
# 复制此文件为 api_keys.yaml 并填入你的真实密钥

# LLM提供商选择: 'claude' 或 'openai'
provider: claude

# Claude API配置
claude:
  api_key: sk-ant-your-api-key-here
  # 可选: 如果使用代理或自定义端点
  # base_url: https://api.anthropic.com

# OpenAI兼容API配置 (包括OpenAI官方、本地模型等)
openai:
  api_key: sk-your-openai-api-key-here
  # 可选: 自定义API端点 (例如本地模型服务)
  # base_url: https://api.openai.com/v1
  # base_url: http://localhost:8000/v1  # 本地模型示例

# TqSDK配置 (期货市场数据)
tqsdk:
  # TqSDK账号 (注册地址: https://www.shinnytech.com/tqsdk)
  username: your_tqsdk_username
  password: your_tqsdk_password
  
  # 使用模拟账户 (true) 或实盘账户 (false)
  # 强烈建议先使用模拟账户测试
  use_sim: true

# 环境变量替代方案
# 也可以使用环境变量来设置API密钥:
# - ANTHROPIC_API_KEY: Claude API密钥
# - OPENAI_API_KEY: OpenAI API密钥
# 环境变量优先级高于配置文件
