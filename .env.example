# =============================================================
# LLM Trading Analyzer — 环境变量配置
# 复制为 .env，填写必填项，然后执行 docker compose up -d
#
# 注意：LLM provider/model/url、爱发电套餐、定价、应用名称等
# 配置在 backend/initial_settings.json（首次启动自动写入DB），
# 之后可通过管理后台修改，无需改此文件。
# =============================================================

# ======================== 必填（4 项）========================

# 生成命令: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# 生成命令: python3 -c "import secrets; print(secrets.token_hex(24))"
ADMIN_TOKEN=

# DeepSeek / OpenAI 兼容接口 API 密钥
LLM_API_KEY=

# 数据库密码（生产环境请使用强密码）
POSTGRES_PASSWORD=

# ======================== 域名 / 跨域 ========================

# 生产环境改为实际域名，如 https://yourdomain.com
ALLOWED_ORIGINS=*

# 前端应用地址，用于生成邮件验证链接
APP_BASE_URL=https://yourdomain.com

# ============== Cloudflare Tunnel（公网接入，可选但推荐）======
# 一键公网 HTTPS：cloudflared 容器主动拨号到 Cloudflare，无需开放 80/443、无需公网 IP、无需管证书。
# 步骤：① Cloudflare → Zero Trust → Networks → Tunnels → Create tunnel，复制 Token 填到下方；
#       ② 该 tunnel → Public Hostnames → Add：域名填你的，Service 填 http://frontend:3000（DNS 由 CF 自动建）。
# 留空则不启用公网接入（仅本地/IP 访问）。
CLOUDFLARE_TUNNEL_TOKEN=

# ======================== 邮件 / Resend（可选）================
# 注册 https://resend.com 免费账号获取 API Key（每月免费 3000 封）
# 留空则验证链接打印到后端日志

RESEND_API_KEY=
EMAIL_FROM=

# ======================== 爱发电 API 凭证（可选）==============
# 在 afdian.net/dashboard/dev 获取（套餐 ID/链接在 initial_settings.json 配置）

AFDIAN_USER_ID=
AFDIAN_API_TOKEN=
AFDIAN_WEBHOOK_TOKEN=

# ======================== 数据库（默认即可）===================

POSTGRES_USER=trader
POSTGRES_DB=trader
