# =============================================================
# LLM Trading Analyzer — 生产环境变量模板
# 复制为 .env 并填写真实值，或直接在 Coolify UI 里配置
# =============================================================

# -------- 数据库 --------
POSTGRES_USER=trader
POSTGRES_PASSWORD=请改为强密码
POSTGRES_DB=trader

# -------- 安全密钥 --------
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=请生成并填入随机密钥

# 管理员接口 token
# 生成命令: python -c "import secrets; print(secrets.token_hex(24))"
ADMIN_TOKEN=请生成并填入管理员token

# -------- LLM 配置 --------
LLM_PROVIDER=openai
LLM_API_KEY=你的API密钥
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.7

# -------- CORS 跨域 --------
# 填写前端域名，多个用逗号分隔（使用 rewrites 代理后浏览器同源，CORS 通常不需要限制）
# 如需限制，填写前端域名，例如: https://app.yourdomain.com
ALLOWED_ORIGINS=*

# -------- 端口（Coolify 一般不需要改，使用内部网络）--------
BACKEND_PORT=8000
FRONTEND_PORT=3000

# -------- 爱发电订阅（可选）--------
AFDIAN_WEBHOOK_TOKEN=
AFDIAN_BASIC_PLAN_ID=
AFDIAN_PREMIUM_PLAN_ID=
AFDIAN_BASIC_LINK=
AFDIAN_PREMIUM_LINK=
